<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ repo_name }} — Case Study</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
  <style>

    * { box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #ffffff;
      color: #1a1a2e;
      margin: 0;
      padding: 0;
    }

    .page {
      max-width: 820px;
      margin: 0 auto;
      padding: 60px 72px;
    }

    /* Header bar */
    .header-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 48px;
      padding-bottom: 24px;
      border-bottom: 3px solid #6366f1;
    }

    .pulse-logo {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6366f1;
    }

    .document-label {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9ca3af;
    }

    /* Markdown content styles */
    .content h1 {
      font-family: 'Merriweather', Georgia, 'Times New Roman', serif;
      font-size: 32px;
      font-weight: 700;
      line-height: 1.25;
      color: #0f172a;
      margin: 0 0 8px 0;
    }

    .content h1 + p,
    .content h1 em {
      font-size: 17px;
      color: #6366f1;
      font-style: italic;
      margin: 0 0 40px 0;
      display: block;
    }

    .content h2 {
      font-size: 18px;
      font-weight: 700;
      color: #0f172a;
      margin: 40px 0 12px 0;
      padding-bottom: 8px;
      border-bottom: 1px solid #e5e7eb;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .content h3 {
      font-size: 16px;
      font-weight: 600;
      color: #374151;
      margin: 24px 0 8px 0;
    }

    .content p {
      font-size: 15px;
      line-height: 1.75;
      color: #374151;
      margin: 0 0 16px 0;
    }

    .content ul, .content ol {
      font-size: 15px;
      line-height: 1.75;
      color: #374151;
      margin: 0 0 16px 0;
      padding-left: 24px;
    }

    .content li {
      margin-bottom: 6px;
    }

    .content strong {
      color: #111827;
      font-weight: 600;
    }

    .content code {
      font-family: 'Courier New', monospace;
      font-size: 13px;
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 4px;
      padding: 1px 6px;
      color: #6366f1;
    }

    .content pre {
      background: #1e293b;
      border-radius: 8px;
      padding: 20px;
      overflow-x: auto;
      margin: 16px 0 24px 0;
    }

    .content pre code {
      background: none;
      border: none;
      color: #e2e8f0;
      padding: 0;
      font-size: 13px;
    }

    .content blockquote {
      border-left: 4px solid #6366f1;
      margin: 16px 0;
      padding: 8px 0 8px 20px;
      color: #6b7280;
      font-style: italic;
    }

    /* Footer */
    .footer {
      margin-top: 64px;
      padding-top: 24px;
      border-top: 1px solid #e5e7eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-left {
      font-size: 12px;
      color: #9ca3af;
    }

    .footer-right {
      font-size: 12px;
      font-weight: 600;
      color: #6366f1;
      letter-spacing: 0.05em;
    }

    /* Accent strip on first h2 */
    .content h2:first-of-type {
      margin-top: 48px;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header-bar">
      <span class="pulse-logo">{{ display_name }}</span>
      <span class="document-label">Case Study</span>
    </div>

    <div class="content">
      {{ body_html | safe }}
    </div>

    <div class="footer">
      <span class="footer-left">Generated by Instant Case Study &mdash; {{ display_name }}</span>
      <span class="footer-right">{{ display_name }}</span>
    </div>
  </div>
</body>
</html>
